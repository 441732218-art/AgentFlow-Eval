{
  "title": "AgentFlow-Eval Overview",
  "uid": "agentflow-eval-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["agentflow", "eval"],
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(agentflow_http_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Suite runs by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(agentflow_suite_runs_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Stage errors (topology)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(agentflow_stage_errors_total[5m])) by (stage, status)",
          "legendFormat": "{{stage}}/{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Slow task samples",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(agentflow_slow_tasks_total[5m])) by (stage)",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token consumption",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(agentflow_tokens_total[5m])) by (stage)",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Judge evaluations",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(agentflow_judge_evaluations_total[5m])) by (mode, status)",
          "legendFormat": "{{mode}}/{{status}}"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "editable": true
}
