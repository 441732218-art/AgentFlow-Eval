# AgentFlow-Eval — PRIVATE profile (enterprise on-prem)
# Copy values into backend/.env.docker for compose

ENV=prod
DEBUG=false
DEPLOY_PROFILE=private
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM

POSTGRES_USER=agentflow
POSTGRES_PASSWORD=REPLACE_STRONG_PASSWORD
POSTGRES_DB=agentflow_eval
DATABASE_URL=postgresql+asyncpg://agentflow:REPLACE_STRONG_PASSWORD@postgres:5432/agentflow_eval

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

AUTH_ENABLED=true
API_KEYS=REPLACE_RANDOM_SECRET:admin:system_admin
RBAC_ENABLED=true
DEFAULT_ROLE=member
ADMIN_ACTORS=admin
TENANCY_ENABLED=true
MULTI_TENANT_ENABLED=false
BILLING_ENABLED=false

PLUGIN_STRICT_MODE=true
PLUGIN_STRICT_ALLOWLIST=true
PLUGIN_MODULES=
PLUGIN_ALLOWLIST=
PLUGIN_SIGNATURE_CHECK=false
PLUGIN_SIGNING_SECRET=
PLUGIN_SIGNATURES=
PLUGIN_MARKET_SEED_EXAMPLES=false

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
METRICS_ENABLED=true
