# AgentFlow-Eval Production Environment Configuration
# Copy to .env and modify for your environment

# ---- Environment Mode ----
# dev | test | prod
ENV=dev
DEBUG=true
SECRET_KEY=generate-a-random-64-char-string-here-for-production

# ---- CORS ----
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# ---- Database ----
# Dev: SQLite
DATABASE_URL=sqlite+aiosqlite:///./agentflow_eval.db
# Prod: PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://agentflow:agentflow_secret@localhost:5432/agentflow_eval
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# 本地开发（无 Redis / Celery Worker）：设为 true，任务在 API 进程内同步执行
# 生产环境：设为 false，并启动 Redis + celery worker
CELERY_TASK_ALWAYS_EAGER=true

# ---- PostgreSQL (for docker-compose) ----
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=agentflow_secret
POSTGRES_DB=agentflow_eval

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=text    # text | json in production
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=30

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ---- Auth (API Key) ----
# 开发默认关闭；生产建议开启
AUTH_ENABLED=false
# 逗号分隔：secret 或 secret:actor_name 或 secret:actor:role
# 例: dev-secret:alice:member,prod-secret:ops:system_admin
API_KEYS=

# ---- Tenancy（按 actor 隔离任务）----
# AUTH_ENABLED=true 时自动启用隔离；也可单独 TENANCY_ENABLED=true
TENANCY_ENABLED=false
# 企业多租户（tenants 表 + X-Tenant-ID）；Lite 保持 false
MULTI_TENANT_ENABLED=false
# 可查看全部任务的 actor，逗号分隔
ADMIN_ACTORS=admin

# ---- Plugins security ----
PLUGINS_ENABLED=true
PLUGIN_STRICT_MODE=false
PLUGIN_STRICT_ALLOWLIST=false
PLUGIN_ALLOWLIST=
PLUGIN_MODULES=
PLUGIN_SIGNATURE_CHECK=false
PLUGIN_SIGNING_SECRET=
PLUGIN_SIGNATURES=
PLUGIN_MARKET_SEED_EXAMPLES=true

# ---- Billing (SaaS) ----
BILLING_ENABLED=false
STRIPE_MODE=mock

# ---- Tool sandbox ----
TOOL_TIMEOUT_SEC=3.0

# ---- Gunicorn ----
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
GUNICORN_TIMEOUT=120

# ---- Observability (Prometheus) ----
METRICS_ENABLED=true


# ---- RBAC ----
RBAC_ENABLED=true
# member（企业默认）；兼容 user / guest / admin 等别名
DEFAULT_ROLE=member
# ACTOR_ROLES=alice:manager,bob:reviewer


# ---- Resilience ----
LLM_RETRY_ENABLED=true
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT_SEC=1.0
LLM_RETRY_MAX_WAIT_SEC=10.0
LLM_CALL_TIMEOUT_SEC=30.0
CIRCUIT_ENABLED=true
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT_SEC=60.0


# ---- Cache ----
CACHE_ENABLED=true
CACHE_WARMUP_ON_STARTUP=false


# ---- Multimodal ----
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=data/uploads
MEDIA_MAX_UPLOAD_BYTES=20971520
VISION_MODEL=gpt-4o-mini
# S3_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET=agentflow
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ---- Deploy profiles (lite | private | saas | auto) ----
DEPLOY_PROFILE=auto
# celery | eager | memory (empty = profile default)
TASK_QUEUE_BACKEND=
BILLING_ENABLED=false
# Stripe Checkout: mock (default) | live
STRIPE_MODE=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/billing?checkout=success
STRIPE_CANCEL_URL=http://localhost:5173/billing?checkout=cancel
# STRIPE_PRICE_IDS=pro:price_xxx,enterprise:price_yyy
SLOW_TASK_THRESHOLD_SEC=30
OBSERVABILITY_KPI_ENABLED=true

# ---- Plugins ----
PLUGINS_ENABLED=true
# Comma-separated dirs to scan for plugin packages
PLUGIN_DIRS=plugins
# Explicit modules, e.g. app.plugins.examples.echo_tool:Plugin
PLUGIN_MODULES=
# Production: only load PLUGIN_MODULES (ignore PLUGIN_DIRS)
PLUGIN_STRICT_ALLOWLIST=false
# Extra allowlist prefixes (comma-separated); empty = no extra filter
PLUGIN_ALLOWLIST=
# Optional local marketplace catalog JSON
PLUGIN_CATALOG_PATH=
PLUGIN_MARKET_SEED_EXAMPLES=true


