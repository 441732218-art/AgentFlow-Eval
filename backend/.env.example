# AgentFlow-Eval Production Environment Configuration
# Copy to .env and modify for your environment

# ---- Environment Mode ----
# dev | test | prod
ENV=dev
DEBUG=true
SECRET_KEY=generate-a-random-64-char-string-here-for-production

# ---- CORS ----
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# ---- Database ----
# Dev: SQLite
DATABASE_URL=sqlite+aiosqlite:///./agentflow_eval.db
# Prod: PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://agentflow:agentflow_secret@localhost:5432/agentflow_eval
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to true for testing without Redis
CELERY_TASK_ALWAYS_EAGER=false

# ---- PostgreSQL (for docker-compose) ----
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=agentflow_secret
POSTGRES_DB=agentflow_eval

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=text    # text | json in production
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=30

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ---- Gunicorn ----
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
GUNICORN_TIMEOUT=120
