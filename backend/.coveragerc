[run]
source = app
omit =
    app/alembic/*
    app/utils/*
    */test_*
    *_test.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if settings.DEBUG:
    except Exception:
show_missing = true
fail_under = 75

[html]
directory = htmlcov

[xml]
output = coverage.xml
