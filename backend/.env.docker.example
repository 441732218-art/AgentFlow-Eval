# AgentFlow-Eval — Docker Compose 环境变量模板
# 复制为 backend/.env.docker 后填写密钥（不要提交 .env.docker）
#
#   copy backend\.env.docker.example backend\.env.docker
#   或运行: powershell -File scripts\generate-deploy-env.ps1

# ---- 运行模式 ----
ENV=prod
DEBUG=false
SECRET_KEY=请替换为随机长字符串

# ---- CORS（浏览器访问来源；Vercel 部署后务必加上 *.vercel.app）----
CORS_ORIGINS=["http://localhost","http://localhost:80","http://127.0.0.1","http://127.0.0.1:80","https://YOUR_VERCEL_APP.vercel.app"]

# ---- PostgreSQL（compose 服务名 postgres）----
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=请替换为强密码
POSTGRES_DB=agentflow_eval
DATABASE_URL=postgresql+asyncpg://agentflow:请替换为强密码@postgres:5432/agentflow_eval

# ---- Redis / Celery（生产必须 eager=false）----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- 日志 / 限流 ----
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ---- 鉴权（交付默认开启）----
# 格式: secret 或 secret:actor 或 secret:actor:role
# 多把钥匙用逗号分隔，例如:
#   API_KEYS=af-admin-xxxx:admin:admin,af-ops-yyyy:ops:manager
AUTH_ENABLED=true
API_KEYS=请替换为随机API密钥:admin:admin
TENANCY_ENABLED=false
ADMIN_ACTORS=admin

# ---- 部署画像 ----
DEPLOY_PROFILE=private
BILLING_ENABLED=false

# ---- Flower（compose profile: ops）----
FLOWER_USER=admin
FLOWER_PASSWORD=请替换为强密码
