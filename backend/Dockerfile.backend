# (c) 2026 AgentFlow-Eval
# Production multi-stage backend image — non-root, slim runtime
# Build: docker build -f Dockerfile.backend -t agentflow-backend:local .

# ---- Builder ----
FROM python:3.12-slim AS builder

WORKDIR /build
ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1

COPY requirements.docker.txt requirements.txt ./
RUN python -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.docker.txt

# ---- Runtime ----
FROM python:3.12-slim AS runtime

LABEL org.opencontainers.image.title="AgentFlow-Eval Backend" \
      org.opencontainers.image.description="Agent evaluation API + Celery worker" \
      org.opencontainers.image.version="1.0.0"

ENV PYTHONPATH=/app \
    PATH="/opt/venv/bin:$PATH" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Non-root user
RUN groupadd --gid 10001 agentflow \
    && useradd --uid 10001 --gid agentflow --shell /usr/sbin/nologin --create-home agentflow \
    && mkdir -p /app/logs \
    && chown -R agentflow:agentflow /app

WORKDIR /app

COPY --from=builder /opt/venv /opt/venv
COPY --chown=agentflow:agentflow app/ app/
COPY --chown=agentflow:agentflow alembic.ini .
COPY --chown=agentflow:agentflow alembic/ alembic/

USER agentflow

HEALTHCHECK --interval=30s --timeout=5s --start-period=25s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health/ready', timeout=4)" || exit 1

EXPOSE 8000

CMD ["gunicorn", "app.main:app", \
     "--worker-class", "uvicorn.workers.UvicornWorker", \
     "--workers", "2", \
     "--bind", "0.0.0.0:8000", \
     "--timeout", "120", \
     "--graceful-timeout", "30", \
     "--access-logfile", "-", \
     "--error-logfile", "-"]
