# AgentFlow-Eval — Vercel Postgres + 自备 API（本机/云主机）
# 复制为 backend/.env.vercel-postgres 后填写
#
# 1) Vercel Storage → Postgres → 复制 POSTGRES_URL
# 2) 运行: .\scripts\setup-vercel-postgres.ps1 -PostgresUrl "postgres://..."
#    或手动把 DATABASE_URL 改成 postgresql+asyncpg://...

ENV=prod
DEBUG=false
SECRET_KEY=请替换为随机长字符串

# 浏览器 → Vercel 前端；CORS 填你的 Vercel 域名
CORS_ORIGINS=["https://YOUR_VERCEL_APP.vercel.app","http://localhost:5173","http://localhost"]

# Vercel/Neon Postgres（必须 asyncpg 驱动前缀）
# 示例: postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/neondb?ssl=require
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DB?ssl=require

# 无 Redis 时可用 eager=true（仅演示）；生产建议 Redis + false
CELERY_TASK_ALWAYS_EAGER=true
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

LOG_LEVEL=INFO
LOG_FORMAT=json
AUTH_ENABLED=false
API_KEYS=
TENANCY_ENABLED=false
ADMIN_ACTORS=admin
