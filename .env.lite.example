# AgentFlow-Eval — LITE profile
# Personal demo / zero Redis-Celery. Copy to backend/.env

ENV=dev
DEBUG=true
DEPLOY_PROFILE=lite
SECRET_KEY=dev-only-change-me

DATABASE_URL=sqlite+aiosqlite:///./agentflow_eval.db
CELERY_TASK_ALWAYS_EAGER=true
# Redis optional in lite (cache/events may no-op or use memory)
REDIS_URL=redis://localhost:6379/0

AUTH_ENABLED=false
RBAC_ENABLED=false
TENANCY_ENABLED=false
MULTI_TENANT_ENABLED=false
BILLING_ENABLED=false

PLUGINS_ENABLED=true
PLUGIN_STRICT_MODE=false
PLUGIN_SIGNATURE_CHECK=false
PLUGIN_MARKET_SEED_EXAMPLES=true

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
LOG_LEVEL=INFO
LOG_FORMAT=text
RATE_LIMIT_ENABLED=false
METRICS_ENABLED=true
