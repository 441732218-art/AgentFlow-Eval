{
  "name": "agentflow-desktop",
  "productName": "AgentFlow Intelligence",
  "version": "1.0.0",
  "description": "AgentFlow Intelligence desktop shell (Windows / macOS / Linux)",
  "main": "main.js",
  "author": "AgentFlow",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder --win --publish never",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never",
    "release:win": "electron-builder --win --publish always",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:all": "electron-builder -mwl --publish never"
  },
  "build": {
    "appId": "ai.agentflow.intelligence",
    "productName": "AgentFlow Intelligence",
    "copyright": "Copyright © 2026 AgentFlow",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "ui",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "441732218-art",
        "repo": "AgentFlow-Eval",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "artifactName": "AgentFlow-${version}-win-${arch}.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AgentFlow Intelligence"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "artifactName": "AgentFlow-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "artifactName": "AgentFlow-${version}-linux-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "AgentFlow-${version}-win-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
