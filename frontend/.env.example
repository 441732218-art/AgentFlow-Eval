# AgentFlow-Eval 前端环境变量
# Vite 仅暴露以 VITE_ 开头的变量（构建时注入）
#
# 本地开发可复制为 frontend/.env.local
# Vercel：在项目 Settings → Environment Variables 配置同名变量后 Redeploy

# 后端 API 根路径（必须含 /api/v1）
#
# 【推荐 · 无缝联调 / Docker 整体打包】同源相对路径 + 反代：
#   VITE_API_BASE_URL=/api/v1
#   - 本地 Vite：vite.config 代理 /api → http://127.0.0.1:8000
#   - Docker 前端 nginx：/api → http://backend:8000
#
# 直连后端（跨域，需 CORS 放行前端源）:
#   VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
# ngrok / 云 API:
#   VITE_API_BASE_URL=https://your-api.example.com/api/v1

VITE_API_BASE_URL=/api/v1
