# (c) 2026 AgentFlow-Eval
# Fully non-root frontend runtime (listen 8080).
# Build: docker build -f Dockerfile.frontend -t agentflow-frontend:local .
# Run:   -p 80:8080 -e API_KEYS=...

FROM node:22-alpine AS builder
WORKDIR /build
ARG VITE_API_BASE_URL=/api/v1
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS runtime

# Writable dirs for non-root nginx
RUN mkdir -p /tmp/nginx /var/cache/nginx /var/run \
    && chown -R nginx:nginx /tmp/nginx /var/cache/nginx /usr/share/nginx/html \
    && sed -i 's,/var/run/nginx.pid,/tmp/nginx/nginx.pid,' /etc/nginx/nginx.conf \
    && sed -i 's/user  nginx;/# user nginx;/' /etc/nginx/nginx.conf || true

COPY --from=builder --chown=nginx:nginx /build/dist /usr/share/nginx/html
COPY --chown=nginx:nginx nginx.conf /etc/nginx/conf.d/default.conf
COPY --chown=nginx:nginx docker-entrypoint.sh /docker-entrypoint-af.sh
RUN chmod +x /docker-entrypoint-af.sh \
    && sed -i 's/listen 80;/listen 8080;/' /etc/nginx/conf.d/default.conf

ENV API_KEYS="" \
    HTML_ROOT=/usr/share/nginx/html \
    NGINX_CONF=/etc/nginx/conf.d/default.conf

# conf.d owned by root — make writable for signature/key substitution
RUN chown nginx:nginx /etc/nginx/conf.d/default.conf

USER nginx

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -qO- http://127.0.0.1:8080/health || exit 1

EXPOSE 8080
ENTRYPOINT ["/docker-entrypoint-af.sh"]
