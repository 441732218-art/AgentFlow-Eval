    "@types/jspdf": "^1.3.3",
    "@types/node": "22.5.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.1",
    "workbox-window": "^7.3.0"
  }
