# AgentFlow-Eval 服务器 / Docker 部署环境变量
# 由 scripts/deploy-server.sh 复制为 backend/.env（不要提交 backend/.env）
#
# Windows 本机 Docker 请用：
#   scripts/generate-deploy-env.ps1  →  backend/.env.docker
#   scripts/docker-up.ps1

# ---- 运行模式 ----
ENV=prod
DEBUG=false
SECRET_KEY=请替换为随机长字符串

# ---- CORS（填你的域名 / 服务器 IP / Vercel 域名）----
# 若仅通过 Nginx 同源访问（前端 80 反代 /api），可保留 localhost
CORS_ORIGINS=["http://localhost","http://YOUR_SERVER_IP","https://YOUR_DOMAIN","https://YOUR_VERCEL_APP.vercel.app"]

# ---- PostgreSQL（docker-compose 内网服务名 postgres）----
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=请替换为强密码
POSTGRES_DB=agentflow_eval
DATABASE_URL=postgresql+asyncpg://agentflow:请替换为强密码@postgres:5432/agentflow_eval

# ---- Redis / Celery（生产必须 eager=false）----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# ---- OpenAI（评测必填）----
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- 日志 / 限流 ----
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ---- 鉴权（交付 / 生产默认开启）----
# 格式: secret 或 secret:actor 或 secret:actor:role（逗号分隔多把钥匙）
AUTH_ENABLED=true
API_KEYS=请替换为随机API密钥:admin:admin
TENANCY_ENABLED=false
ADMIN_ACTORS=admin

# ---- Flower 监控（docker-compose 内 basic-auth）----
FLOWER_USER=admin
FLOWER_PASSWORD=请替换为强密码
