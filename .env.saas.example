# AgentFlow-Eval — SAAS profile
# Multi-tenant + billing + strict plugins

ENV=prod
DEBUG=false
DEPLOY_PROFILE=saas
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM

DATABASE_URL=postgresql+asyncpg://agentflow:REPLACE@postgres:5432/agentflow_eval
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

AUTH_ENABLED=true
API_KEYS=REPLACE_ROOT:ops:system_admin,REPLACE_TA:alice:tenant_admin
RBAC_ENABLED=true
DEFAULT_ROLE=member
ADMIN_ACTORS=ops
TENANCY_ENABLED=true
MULTI_TENANT_ENABLED=true
BILLING_ENABLED=true
STRIPE_MODE=mock
# STRIPE_MODE=live
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_IDS=pro:price_xxx,enterprise:price_yyy

PLUGIN_STRICT_MODE=true
PLUGIN_STRICT_ALLOWLIST=true
PLUGIN_MODULES=app.plugins.examples.echo_tool:Plugin
PLUGIN_ALLOWLIST=app.plugins.examples
PLUGIN_SIGNATURE_CHECK=true
PLUGIN_SIGNING_SECRET=REPLACE_HMAC_SECRET
PLUGIN_SIGNATURES=
PLUGIN_MARKET_SEED_EXAMPLES=false

OPENAI_API_KEY=
CORS_ORIGINS=["https://app.example.com"]
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
METRICS_ENABLED=true
